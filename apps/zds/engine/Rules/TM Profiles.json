{
  "_meta": {
    "description": "GLCR Grave Shift TM competency profiles, skill scores, and comment log.",
    "skill_scale": "1-10. 1-3 = new/trainee, 4-5 = developing, 6-7 = solid/reliable, 8-9 = strong, 10 = elite. Scores updated through shift debrief conversation only.",
    "comment_categories": [
      "Performance",
      "Attitude",
      "Physical",
      "Request",
      "Feedback",
      "Administrative"
    ],
    "comment_sentiments": [
      "Positive",
      "Negative",
      "Neutral",
      "Flag"
    ],
    "last_updated": "2026-05-03",
    "schema_version": "2.1",
    "schema_changes_5_1_26": {
      "preferences": {
        "purpose": "Per-TM placement preferences (avoid/prefer specific slots, areas, or categories)",
        "shape": "List of {stance, strength, target, note?, added_date, last_reviewed?}",
        "stance_values": [
          "avoid",
          "prefer"
        ],
        "strength_values": [
          "soft",
          "hard"
        ],
        "target_forms": [
          "Specific slot \u2014 e.g., 'Zone 8', 'WRR 7', 'Z9 SR'",
          "Area \u2014 e.g., 'area:Lobby', 'area:Z9', 'area:C3'",
          "Category \u2014 e.g., 'category:sweeper', 'category:restroom', 'category:trash'"
        ],
        "engine_behavior": {
          "soft": "Adds a +/- penalty to the scorecard preference_fit component. Yields when no better candidates exist.",
          "hard": "Filters the candidate pool. If no other eligible candidates remain for a must-fill slot, engine overrides and logs HARD_PREFERENCE_OVERRIDDEN to audit."
        }
      },
      "pair_affinities": {
        "purpose": "Per-TM pairing preferences with other named TMs. Engine checks adjacent placements (zones, RR mens/womens split, Z9 SR buddy, sweeper co-route).",
        "shape": "List of {with, stance, strength, note?, added_date}",
        "engine_behavior": "Soft: scorecard pair_affinity component penalizes/bonuses adjacent placement. Hard: filters out the conflict pair from adjacent placement when alternatives exist."
      },
      "legacy_compat": "Existing slot_preference field (e.g. 'restroom', 'no_sweeper', 'sweeper_capable') still honored by engine. Migrate to preferences/pair_affinities format over time when convenient."
    },
    "schema_changes_5_3_26": {
      "accommodations": {
        "purpose": "Per-TM accommodations \u2014 separate from preferences. These are protected accessibility/medical/physical/sensory needs that the engine MUST respect (filtered out of candidate pool, audit-logged on override).",
        "shape": "List of {type, severity, target?, note, added_date, status}",
        "type_values": [
          "physical",
          "sensory",
          "medical",
          "temporary",
          "other"
        ],
        "severity_values": [
          "soft",
          "hard",
          "absolute"
        ],
        "status_values": [
          "active",
          "resolved",
          "review_due"
        ],
        "engine_behavior": {
          "soft": "Same as soft preference \u2014 scorecard penalty only.",
          "hard": "Filtered from candidate pool. Override audit if must-fill empties.",
          "absolute": "Filtered with no override possible \u2014 slot stays empty before TM is placed."
        },
        "vs_preferences": "Accommodations are PROTECTED. Different lifetime (persistent vs revisable), different audit category (HARD_ACCOMMODATION_OVERRIDDEN vs HARD_PREFERENCE_OVERRIDDEN), different intent (must-respect vs nice-to-respect)."
      }
    }
  },
