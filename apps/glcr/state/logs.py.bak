"""
state/logs.py — LogsState

Powers the Logs page: full browsable history of all notes with
type-filter tabs, days-back selector, and live search.
"""

import reflex as rx
from .base import AppState
from shared.db import get_logs


class LogsState(AppState):
    items:       list[dict] = []
    type_filter: str  = "all"      # all | observations | flags | kudos | reference
    days_back:   int  = 7          # 0 = all time
    search:      str  = ""
    loading:     bool = True
    view_mode:   str  = "feed"     # "feed" | "timeline"

    # ── Computed vars ─────────────────────────────────────────────────────────

    @rx.var
    def item_count(self) -> int:
        return len(self.items)

    @rx.var
    def days_label(self) -> str:
        if self.days_back == 0:
            return "All time"
        if self.days_back == 1:
            return "Today"
        return f"Last {self.days_back} days"

    @rx.var
    def page_summary(self) -> str:
        n = self.item_count
        suffix = " (filtered)" if self.search.strip() or self.type_filter != "all" else ""
        return f"{n} entr{'ies' if n != 1 else 'y'}{suffix}."

    # ── Events ────────────────────────────────────────────────────────────────

    @rx.event
    async def load_logs(self):
        self.loading = True
        yield
        self.items = get_logs(self.type_filter, self.days_back, self.search)
        self.loading = False

    @rx.event
    async def set_type_filter(self, value: str):
        self.type_filter = value
        yield LogsState.load_logs

    @rx.event
    async def set_days_back(self, value: str):
        """Receives value as string from select element."""
        try:
            self.days_back = int(value)
        except ValueError:
            self.days_back = 7
        yield LogsState.load_logs

    @rx.event
    async def set_search(self, value: str):
        self.search = value
        yield LogsState.load_logs

    @rx.event
    def set_view_mode(self, mode: str):
        self.view_mode = mode
