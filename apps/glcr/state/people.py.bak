"""
state/people.py — PeopleState

Full TM people system: grid view + right-side profile drawer.
The drawer has four tabs:
  profile      — skill score, status, score history (editable)
  eligibility  — per-zone Y/N toggles (sourced from Eligibility Roster.xlsx
                 with Supabase overrides)
  preferences  — placement preferences + pair affinities (add/remove)
  notes        — recent note history (read-only)
"""

from datetime import date
import reflex as rx
from .base import AppState
from shared.db import (
    get_people, get_tm_notes, get_tm_full_profile,
    update_tm_metadata, update_tm_eligibility,
    find_tm_id_by_name,
    ELIGIBILITY_SLOTS, SLOT_GROUPS,
)


class PeopleState(AppState):
    # ── Grid ──────────────────────────────────────────────────────────────────
    people:       list[dict] = []
    search_query: str        = ""
    loading:      bool       = True

    # View controls
    view_mode:   str = "grid"    # "grid" | "list"
    sort_by:     str = "score"   # "score" | "name" | "rank"
    pool_filter: str = "active"  # "all" | "active" | "loa" | "accom" | "trainer"

    # ── Drawer shared ─────────────────────────────────────────────────────────
    drawer_open:    bool       = False
    drawer_tab:     str        = "profile"   # profile | eligibility | preferences | notes
    drawer_tm_id:   str        = ""
    drawer_loading: bool       = False

    # These flat lists are extracted from the full profile so rx.foreach can use them.
    # They are refreshed every time the drawer opens or a save completes.
    drawer_name:          str        = ""
    drawer_full_name:     str        = ""
    drawer_skill_score:   float      = 5.0
    drawer_status:        str        = "active"
    drawer_loa_note:      str        = ""
    drawer_score_history: list[dict] = []
    drawer_accommodations:list[dict] = []
    drawer_preferences:   list[dict] = []
    drawer_affinities:    list[dict] = []
    drawer_notes:         list[dict] = []
    # Eligibility as a flat list so rx.foreach works:
    # Each item: {slot: str, eligible: bool, group: str}
    drawer_eligibility:   list[dict] = []
    elig_dirty:   bool = False
    elig_saving:  bool = False
    elig_status:  str  = ""   # "" | "saved" | "error"

    # ── Profile editing ───────────────────────────────────────────────────────
    editing_profile:     bool  = False
    edit_score:          str   = ""   # string binding for <input type=number>
    edit_score_reason:   str   = ""
    edit_status:         str   = "active"
    edit_loa_note:       str   = ""
    profile_saving:      bool  = False
    profile_status:      str   = ""   # "" | "saved" | "error"

    # ── Accommodation form ────────────────────────────────────────────────────
    accom_adding:      bool = False
    new_accom_type:    str  = "physical"
    new_accom_severity:str  = "hard"
    new_accom_target:  str  = ""
    new_accom_note:    str  = ""
    accom_saving:      bool = False

    # ── Preference form ───────────────────────────────────────────────────────
    pref_adding:       bool = False
    new_pref_stance:   str  = "avoid"
    new_pref_strength: str  = "soft"
    new_pref_target:   str  = ""
    new_pref_note:     str  = ""
    pref_saving:       bool = False

    # ── Pair affinity form ────────────────────────────────────────────────────
    aff_adding:        bool = False
    new_aff_with:      str  = ""
    new_aff_stance:    str  = "avoid"
    new_aff_strength:  str  = "soft"
    new_aff_note:      str  = ""
    aff_saving:        bool = False

    # ── Computed vars ─────────────────────────────────────────────────────────

    @rx.var
    def filtered_people(self) -> list[dict]:
        q = self.search_query.lower().strip()
        rows = self.people

        # Text search
        if q:
            rows = [
                p for p in rows
                if q in p.get("name", "").lower() or q in p.get("full_name", "").lower()
            ]

        # Pool / status filter
        if self.pool_filter == "active":
            rows = [p for p in rows if p.get("active", True)]
        elif self.pool_filter == "loa":
            rows = [p for p in rows if p.get("status") == "loa"]
        elif self.pool_filter == "accom":
            rows = [p for p in rows if p.get("has_no_sweeper") or p.get("has_am_only")]
        elif self.pool_filter == "trainer":
            rows = [p for p in rows if p.get("is_trainer")]
        # "all" → no filter

        # Sort
        if self.sort_by == "name":
            rows = sorted(rows, key=lambda p: p.get("name", "").lower())
        elif self.sort_by == "rank":
            rows = sorted(rows, key=lambda p: (p.get("rank") or 99))
        else:  # "score" — default
            rows = sorted(rows, key=lambda p: -(p.get("skill_score") or 0))

        return rows

    @rx.var
    def people_count(self) -> int:
        return len(self.filtered_people)

    @rx.var
    def page_summary(self) -> str:
        n = self.people_count
        q = self.search_query.strip()
        if q:
            return f"{n} team member{'s' if n != 1 else ''} matching \"{q}\"."
        return f"{n} team members on the grave roster."

    @rx.var
    def drawer_score_label(self) -> str:
        s = self.drawer_skill_score
        return f"{s:g}" if s == int(s) else str(s)

    @rx.var
    def drawer_score_tier(self) -> str:
        s = self.drawer_skill_score
        if s >= 8: return "top"
        if s >= 6: return "solid"
        if s >= 5: return "standard"
        return "developing"

    @rx.var
    def drawer_score_badge_cls(self) -> str:
        return f"score-badge score-badge-{self.drawer_score_tier}"

    @rx.var
    def sparkline_svg(self) -> str:
        """
        Mini SVG polyline of the TM's score history.
        Returns "" if fewer than 2 data points exist.
        Series: [first_old, h0_new, h1_new, … last_new]  — full trajectory.
        """
        history = self.drawer_score_history
        if not history:
            return ""
        # Build full point series
        points: list[float] = []
        first = history[0]
        try:
            points.append(float(first.get("old", 5)))
        except (TypeError, ValueError):
            points.append(5.0)
        for h in history:
            try:
                points.append(float(h.get("new", 5)))
            except (TypeError, ValueError):
                points.append(5.0)
        if len(points) < 2:
            return ""
        W, H = 160, 40
        pad = 3
        mn = min(points); mx = max(points)
        span = mx - mn if mx != mn else 2.0
        def sx(i: int) -> int:
            return pad + int(i * (W - pad * 2) / (len(points) - 1))
        def sy(v: float) -> int:
            return (H - pad) - int((v - mn) / span * (H - pad * 2))
        pts = " ".join(f"{sx(i)},{sy(v)}" for i, v in enumerate(points))
        last_x, last_y = sx(len(points) - 1), sy(points[-1])
        last_score = points[-1]
        score_str = str(int(last_score)) if last_score == int(last_score) else str(last_score)
        return (
            f'<svg width="{W}" height="{H}" viewBox="0 0 {W} {H}" '
            f'xmlns="http://www.w3.org/2000/svg" style="display:block">'
            f'<polyline points="{pts}" fill="none" stroke="var(--accent-blue)" '
            f'stroke-width="2" stroke-linejoin="round" stroke-linecap="round" opacity="0.7"/>'
            f'<circle cx="{last_x}" cy="{last_y}" r="3" fill="var(--accent-blue)"/>'
            f'<text x="{last_x + 5}" y="{last_y + 4}" font-size="9" fill="var(--fg-2)" '
            f'font-family="system-ui,sans-serif">{score_str}</text>'
            f'</svg>'
        )

    @rx.var
    def drawer_note_count(self) -> int:
        return len(self.drawer_notes)

    @rx.var
    def drawer_notes_preview(self) -> list[dict]:
        """First 4 notes — used by the global TM quick-peek drawer."""
        return self.drawer_notes[:4]

    @rx.var
    def drawer_elig_count(self) -> int:
        return sum(1 for e in self.drawer_eligibility if e.get("eligible"))

    @rx.var
    def can_save_profile(self) -> bool:
        try:
            s = float(self.edit_score)
            return 0 < s <= 10 and not self.profile_saving
        except (ValueError, TypeError):
            return False

    # ── View control events ───────────────────────────────────────────────────

    @rx.event
    def set_view_mode(self, m: str):
        self.view_mode = m

    @rx.event
    def set_sort_by(self, v: str):
        self.sort_by = v

    @rx.event
    def set_pool_filter(self, v: str):
        self.pool_filter = v

    # ── Grid events ───────────────────────────────────────────────────────────

    @rx.event
    async def load_people(self):
        self.loading = True
        yield
        self.people = get_people()
        self.loading = False

    @rx.event
    def set_search(self, value: str):
        self.search_query = value

    # ── Drawer open/close ─────────────────────────────────────────────────────

    @rx.event
    async def open_drawer(self, tm_id: str):
        self.drawer_tm_id   = tm_id
        self.drawer_open    = True
        # Tab is NOT reset — preserves the last active tab across TM switches.
        # On very first open drawer_tab defaults to "profile" via the class initializer.
        self.drawer_loading = True
        self.editing_profile = False
        self.accom_adding   = False
        self.pref_adding    = False
        self.aff_adding     = False
        self.elig_dirty     = False
        self.elig_status    = ""
        self.profile_status = ""
        yield
        self._load_drawer_data(tm_id)

    @rx.event
    async def open_drawer_by_name(self, name: str):
        """
        Open the TM drawer by display name (e.g. from a feed row or pattern bar).
        Does a name→id lookup then delegates to the normal open_drawer flow.
        Silently no-ops if no matching TM is found.
        """
        if not name or not name.strip():
            return
        self.drawer_loading = True
        self.drawer_open    = True
        self.drawer_tab     = "profile"
        self.editing_profile = False
        yield
        tm_id = find_tm_id_by_name(name.strip())
        if not tm_id:
            self.drawer_open    = False
            self.drawer_loading = False
            return
        self.drawer_tm_id = tm_id
        self._load_drawer_data(tm_id)

    def _load_drawer_data(self, tm_id: str):
        """Sync helper — loads full profile + notes into drawer state vars."""
        profile = get_tm_full_profile(tm_id)
        if not profile:
            self.drawer_loading = False
            return

        self.drawer_name          = profile.get("name", "")
        self.drawer_full_name     = profile.get("full_name", "")
        self.drawer_skill_score   = float(profile.get("skill_score", 5))
        self.drawer_status        = profile.get("status", "active")
        self.drawer_loa_note      = profile.get("loa_note", "")
        self.drawer_score_history = profile.get("score_history") or []
        self.drawer_accommodations= profile.get("accommodations") or []
        self.drawer_preferences   = profile.get("preferences") or []
        self.drawer_affinities    = profile.get("pair_affinities") or []

        # Build flat eligibility list for rx.foreach
        raw_elig = profile.get("eligibility") or {}
        elig_list = []
        for group, slots in SLOT_GROUPS.items():
            for slot in slots:
                elig_list.append({
                    "slot":     slot,
                    "eligible": bool(raw_elig.get(slot, False)),
                    "group":    group,
                })
        self.drawer_eligibility = elig_list

        # Notes loaded separately (async)
        self.drawer_notes   = get_tm_notes(self.drawer_name, limit=30)
        self.drawer_loading = False

    @rx.event
    def close_drawer(self):
        self.drawer_open     = False
        self.editing_profile = False
        self.accom_adding    = False
        self.pref_adding     = False
        self.aff_adding      = False

    @rx.event
    def set_drawer_tab(self, tab: str):
        self.drawer_tab = tab

    # ── Profile editing ───────────────────────────────────────────────────────

    @rx.event
    def start_edit_profile(self):
        s = self.drawer_skill_score
        self.edit_score        = str(int(s) if s == int(s) else s)
        self.edit_score_reason = ""
        self.edit_status       = self.drawer_status
        self.edit_loa_note     = self.drawer_loa_note
        self.editing_profile   = True
        self.profile_status    = ""

    @rx.event
    def cancel_edit_profile(self):
        self.editing_profile = False
        self.profile_status  = ""

    @rx.event
    def set_edit_score(self, v: float):
        # Input type=number delivers a float; store as string for display binding
        self.edit_score = str(int(v) if v == int(v) else v) if v else ""

    @rx.event
    def set_edit_score_reason(self, v: str):
        self.edit_score_reason = v

    @rx.event
    def set_edit_status(self, v: str):
        self.edit_status = v

    @rx.event
    def set_edit_loa_note(self, v: str):
        self.edit_loa_note = v

    @rx.event
    async def save_profile(self):
        if not self.can_save_profile:
            return
        self.profile_saving = True
        yield
        try:
            new_score = float(self.edit_score)
            old_score = self.drawer_skill_score
            today     = date.today().isoformat()

            updates: dict = {
                "status":   self.edit_status,
                "loa_note": self.edit_loa_note,
            }

            if new_score != old_score:
                updates["skill_score"] = new_score
                # Append to score_history
                history = list(self.drawer_score_history)
                history.append({
                    "date":   today,
                    "old":    old_score,
                    "new":    new_score,
                    "reason": f"Brian: {self.edit_score_reason}" if self.edit_score_reason else "Brian: dashboard update",
                })
                updates["score_history"] = history

            ok = update_tm_metadata(self.drawer_tm_id, updates)
            if ok:
                self.drawer_skill_score  = new_score
                self.drawer_status       = self.edit_status
                self.drawer_loa_note     = self.edit_loa_note
                if "score_history" in updates:
                    self.drawer_score_history = updates["score_history"]
                self.editing_profile = False
                self.profile_status  = "saved"
                # Refresh the grid card too
                yield PeopleState.load_people
            else:
                self.profile_status = "error"
        except Exception:
            self.profile_status = "error"
        finally:
            self.profile_saving = False

    # ── Accommodation add/remove ──────────────────────────────────────────────

    @rx.event
    def open_accom_form(self):
        self.accom_adding       = True
        self.new_accom_type     = "physical"
        self.new_accom_severity = "hard"
        self.new_accom_target   = ""
        self.new_accom_note     = ""

    @rx.event
    def close_accom_form(self):
        self.accom_adding = False

    @rx.event
    def set_accom_type(self, v: str):     self.new_accom_type = v
    @rx.event
    def set_accom_severity(self, v: str): self.new_accom_severity = v
    @rx.event
    def set_accom_target(self, v: str):   self.new_accom_target = v
    @rx.event
    def set_accom_note(self, v: str):     self.new_accom_note = v

    @rx.event
    async def save_accom(self):
        self.accom_saving = True
        yield
        new_entry = {
            "type":       self.new_accom_type,
            "severity":   self.new_accom_severity,
            "target":     self.new_accom_target.strip(),
            "note":       self.new_accom_note.strip(),
            "added_date": date.today().isoformat(),
            "status":     "active",
        }
        updated = list(self.drawer_accommodations) + [new_entry]
        ok = update_tm_metadata(self.drawer_tm_id, {"accommodations": updated})
        if ok:
            self.drawer_accommodations = updated
            self.accom_adding = False
        self.accom_saving = False

    @rx.event
    async def remove_accom(self, idx: int):
        updated = [a for i, a in enumerate(self.drawer_accommodations) if i != idx]
        ok = update_tm_metadata(self.drawer_tm_id, {"accommodations": updated})
        if ok:
            self.drawer_accommodations = updated

    # ── Preference add/remove ─────────────────────────────────────────────────

    @rx.event
    def open_pref_form(self):
        self.pref_adding       = True
        self.new_pref_stance   = "avoid"
        self.new_pref_strength = "soft"
        self.new_pref_target   = ""
        self.new_pref_note     = ""

    @rx.event
    def close_pref_form(self):
        self.pref_adding = False

    @rx.event
    def set_pref_stance(self, v: str):   self.new_pref_stance = v
    @rx.event
    def set_pref_strength(self, v: str): self.new_pref_strength = v
    @rx.event
    def set_pref_target(self, v: str):   self.new_pref_target = v
    @rx.event
    def set_pref_note(self, v: str):     self.new_pref_note = v

    @rx.event
    async def save_pref(self):
        self.pref_saving = True
        yield
        new_entry = {
            "stance":    self.new_pref_stance,
            "strength":  self.new_pref_strength,
            "target":    self.new_pref_target.strip(),
            "note":      self.new_pref_note.strip(),
            "added_date": date.today().isoformat(),
        }
        updated = list(self.drawer_preferences) + [new_entry]
        ok = update_tm_metadata(self.drawer_tm_id, {"preferences": updated})
        if ok:
            self.drawer_preferences = updated
            self.pref_adding = False
        self.pref_saving = False

    @rx.event
    async def remove_pref(self, idx: int):
        updated = [p for i, p in enumerate(self.drawer_preferences) if i != idx]
        ok = update_tm_metadata(self.drawer_tm_id, {"preferences": updated})
        if ok:
            self.drawer_preferences = updated

    # ── Pair affinity add/remove ──────────────────────────────────────────────

    @rx.event
    def open_aff_form(self):
        self.aff_adding      = True
        self.new_aff_with    = ""
        self.new_aff_stance  = "avoid"
        self.new_aff_strength= "soft"
        self.new_aff_note    = ""

    @rx.event
    def close_aff_form(self):
        self.aff_adding = False

    @rx.event
    def set_aff_with(self, v: str):     self.new_aff_with = v
    @rx.event
    def set_aff_stance(self, v: str):   self.new_aff_stance = v
    @rx.event
    def set_aff_strength(self, v: str): self.new_aff_strength = v
    @rx.event
    def set_aff_note(self, v: str):     self.new_aff_note = v

    @rx.event
    async def save_aff(self):
        self.aff_saving = True
        yield
        new_entry = {
            "with":      self.new_aff_with.strip(),
            "stance":    self.new_aff_stance,
            "strength":  self.new_aff_strength,
            "note":      self.new_aff_note.strip(),
            "added_date": date.today().isoformat(),
        }
        updated = list(self.drawer_affinities) + [new_entry]
        ok = update_tm_metadata(self.drawer_tm_id, {"pair_affinities": updated})
        if ok:
            self.drawer_affinities = updated
            self.aff_adding = False
        self.aff_saving = False

    @rx.event
    async def remove_aff(self, idx: int):
        updated = [a for i, a in enumerate(self.drawer_affinities) if i != idx]
        ok = update_tm_metadata(self.drawer_tm_id, {"pair_affinities": updated})
        if ok:
            self.drawer_affinities = updated

    # ── Eligibility editing ───────────────────────────────────────────────────

    @rx.event
    def toggle_elig(self, slot: str):
        """Toggle a single slot and mark the eligibility as dirty."""
        self.drawer_eligibility = [
            {**e, "eligible": not e["eligible"]} if e["slot"] == slot else e
            for e in self.drawer_eligibility
        ]
        self.elig_dirty  = True
        self.elig_status = ""

    @rx.event
    async def save_eligibility(self):
        self.elig_saving = True
        yield
        elig_dict = {e["slot"]: e["eligible"] for e in self.drawer_eligibility}
        ok = update_tm_eligibility(self.drawer_tm_id, elig_dict)
        self.elig_saving = False
        if ok:
            self.elig_dirty  = False
            self.elig_status = "saved"
        else:
            self.elig_status = "error"
