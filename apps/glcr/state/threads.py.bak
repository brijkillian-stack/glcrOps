"""
state/threads.py — ThreadsState

Loads auto-grouped topics from the threads table.
"""

import reflex as rx
from .base import AppState
from shared.db import list_threads, get_thread_notes


class ThreadsState(AppState):
    # ── Threads data ──────────────────────────────────────────────────────────
    threads: list[dict] = []
    expanded_thread_id: str = ""
    expanded_thread_notes: list[dict] = []

    # ── Page state ────────────────────────────────────────────────────────────
    loading: bool = True
    error: str = ""

    # ── Events ────────────────────────────────────────────────────────────────

    @rx.event
    async def load_threads(self):
        """Load all threads from the database."""
        self.loading = True
        self.error = ""
        self.expanded_thread_id = ""
        self.expanded_thread_notes = []
        yield

        try:
            self.threads = list_threads(limit=50)
        except Exception as exc:
            self.error = str(exc)
        finally:
            self.loading = False

    @rx.event
    async def expand_thread(self, thread_id: str):
        """Expand a thread to show its linked notes."""
        if self.expanded_thread_id == thread_id:
            # Toggle off
            self.expanded_thread_id = ""
            self.expanded_thread_notes = []
        else:
            # Toggle on
            self.expanded_thread_id = thread_id
            try:
                self.expanded_thread_notes = get_thread_notes(thread_id, limit=20)
            except Exception as exc:
                self.error = str(exc)

    @rx.event
    async def reload_threads(self):
        """Manual refresh button."""
        yield ThreadsState.load_threads
