{
    auto_https off
    admin off
    log {
        output stdout
        format console
        level INFO
    }
}

:{$PORT} {
    log

    # ─── Auth ───────────────────────────────────────────────────────────────
    # Caddy basic-auth was removed 2026-05-05 (Path A). The Supabase
    # magic-link layer (shared/auth.py + persisted refresh tokens via
    # rx.LocalStorage) is now the only auth gate. Magic-link login holds
    # for ~30 days per device with auto-refresh on activity.
    #
    # If team-password access is needed later, add an in-app /site-password
    # route (Path C from the auth-paths discussion) — DO NOT reintroduce
    # browser-popup basic_auth here; iOS Safari PWA mode does not persist
    # those credentials reliably.
    #
    # The Render env vars BASIC_AUTH_USER and BASIC_AUTH_HASH are now
    # unused. Safe to delete from the Render dashboard.

    # ─── Routes ─────────────────────────────────────────────────────────────

    # Health endpoint for Render's port scan.
    handle /health {
        respond "ok" 200
    }

    # Reflex backend: WebSocket events, RPC, uploads, healthchecks, auth.
    @backend path /_event /_event/* /ping /ping/* /_upload /_upload/* /_health /_health/* /_all_routes /_all_routes/* /auth-codespace /auth-codespace/*
    handle @backend {
        reverse_proxy localhost:8000
    }

    # Print cache (2026-05-06 — fixes Print Day 404).
    # apps/zds/state.py writes per-night and per-week deployment HTML to
    # /app/print_cache/. Decoupled from Reflex's .web/build/client/ so it
    # survives reflex-export hiccups and doesn't depend on the static-export
    # path layout staying stable across Reflex versions.
    handle /print_cache/* {
        root * /app
        file_server
    }

    # Static frontend (pre-exported).
    handle {
        root * /app/.web/build/client
        try_files {path} {path}/ /index.html
        file_server
    }
}
